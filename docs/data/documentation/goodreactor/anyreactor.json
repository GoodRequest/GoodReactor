ally and mutated by reducing events on a concrete underlying reactor."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Lifecycle: "},{"code":"AnyReactor","type":"codeVoice"},{"type":"text","text":" does not automatically start the wrapped reactor."},{"type":"text","text":" "},{"text":"Call ","type":"text"},{"code":"start()","type":"codeVoice"},{"text":" explicitly to initialize external subscriptions.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Events from "},{"code":"send(action:)","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"send(action:) async"},{"type":"text","text":", and "},{"type":"codeVoice","code":"send(destination:)"},{"type":"text","text":" are forwarded to the base reactor."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example:"}]},{"syntax":"swift","code":["struct ProfileView: View {","    @ViewModel var reactor: AnyReactor = ProfileViewModel().eraseToAnyReactor()","","    var body: some View {","        VStack {","            Text(reactor.name)              \/\/ dynamic access into state","            if reactor.isLoading { ProgressView() }","            Button(\"Reload\") { reactor.send(action: .reload) }","        }","    }","}"],"type":"codeListing"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"Mutation type is intentionally erased. If you need access to mutations, prefer using concrete Reactor type instead."}],"type":"paragraph"}],"type":"aside","name":"Note"}]}],"references":{"doc://GoodReactor/documentation/GoodReactor/AnyReactor/Equatable-Implementations":{"identifier":"doc:\/\/GoodReactor\/documentation\/GoodReactor\/AnyReactor\/Equatable-Implementations","abstract":[],"type":"topic","url":"\/documentation\/goodreactor\/anyreactor\/equatable-implementations","title":"Equatable Implementations","role":"collectionGroup","kind":"article"},"doc://GoodReactor/SQ":{"title":"Swi